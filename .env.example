# Railway auto-injects this when a Postgres service is attached. Locally,
# point at a development database you control (a docker-compose postgres,
# a Neon/Supabase free-tier db, etc.).
DATABASE_URL="postgresql://user:password@localhost:5432/retrochallenges?schema=public"

# Shared secret between the desktop app and this API. The Electron app
# sends it as the X-RC-Submission-Secret header on every POST /api/runs.
# Treat as rotatable — binary leaks are the reason we have moderation.
# Generate with: openssl rand -hex 32
SUBMISSION_SECRET=""

# Admin-only token. Used by DELETE /api/admin/runs/:id to hide disputed
# or fraudulent runs. Keep this in a password manager, not in the binary.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=""
